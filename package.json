{
    "name": "traderefer",
    "version": "0.1.0",
    "packageManager": "pnpm@10.30.0",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "seo:rescue-audit": "node scripts/seo_rescue_audit.mjs",
        "seo:monitor": "node scripts/seo_rescue_monitor.mjs",
        "gsc:submit-sitemap": "node scripts/gsc_submit_sitemap.mjs",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "devDependencies": {
        "next": "~16.2.1",
        "prettier": "latest",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "turbo": "latest"
    },
    "pnpm": {
        "overrides": {},
        "neverBuiltDependencies": [],
        "peerDependencyRules": {
            "allowAny": [
                "react",
                "react-dom"
            ]
        }
    },
    "dependencies": {
        "googleapis": "^171.4.0",
        "open": "^11.0.0",
        "pg": "^8.20.0"
    }
}
